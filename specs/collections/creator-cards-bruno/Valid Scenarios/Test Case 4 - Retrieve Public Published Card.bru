meta {
  name: Test Case 4 - Retrieve Public Published Card
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/creator-cards/george-cooks
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.status: eq success
  res.body.data.id: isDefined
  res.body.data._id: isUndefined
  res.body.data.access_code: isUndefined
}
