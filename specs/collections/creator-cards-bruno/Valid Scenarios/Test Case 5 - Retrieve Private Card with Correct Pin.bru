meta {
  name: Test Case 5 - Retrieve Private Card with Correct Pin
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/creator-cards/vip-rate-card?access_code=A1B2C3
  body: none
  auth: none
}

query {
  access_code: A1B2C3
}

assert {
  res.status: eq 200
  res.body.status: eq success
  res.body.data.id: isDefined
  res.body.data._id: isUndefined
  res.body.data.access_code: isUndefined
}
