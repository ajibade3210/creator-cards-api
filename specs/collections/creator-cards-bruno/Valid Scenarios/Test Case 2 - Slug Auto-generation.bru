meta {
  name: Test Case 2 - Slug Auto-generation
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/creator-cards
  body: json
  auth: none
}

body:json {
  {
    "title": "Ada Designs Things",
    "creator_reference": "crt_a1b2c3d4e5f6g7h8",
    "status": "published"
  }
}

assert {
  res.status: eq 200
  res.body.status: eq success
  res.body.data.slug: eq ada-designs-things
}
