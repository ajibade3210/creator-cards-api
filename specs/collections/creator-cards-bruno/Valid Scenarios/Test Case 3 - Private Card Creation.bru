meta {
  name: Test Case 3 - Private Card Creation
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/creator-cards
  body: json
  auth: none
}

body:json {
  {
    "title": "VIP Rate Card",
    "creator_reference": "crt_x9y8z7w6v5u4t3s2",
    "status": "published",
    "access_type": "private",
    "access_code": "A1B2C3"
  }
}

assert {
  res.status: eq 200
  res.body.status: eq success
  res.body.data.access_code: eq A1B2C3
}
