meta {
  name: Test Case 10 - Framework Validation Failure (Status Archived)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/creator-cards
  body: json
  auth: none
}

body:json {
  {
    "title": "Bad Status Card",
    "creator_reference": "crt_q1w2e3r4t5y6u7i8",
    "status": "archived"
  }
}

assert {
  res.status: eq 400
  res.body.status: eq error
}
