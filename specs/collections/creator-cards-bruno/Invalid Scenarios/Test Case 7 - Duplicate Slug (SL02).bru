meta {
  name: Test Case 7 - Duplicate Slug (SL02)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/creator-cards
  body: json
  auth: none
}

body:json {
  {
    "title": "Another George",
    "slug": "george-cooks",
    "creator_reference": "crt_m1n2b3v4c5x6z7l8",
    "status": "published"
  }
}

assert {
  res.status: eq 400
  res.body.status: eq error
  res.body.code: eq SL02
}
