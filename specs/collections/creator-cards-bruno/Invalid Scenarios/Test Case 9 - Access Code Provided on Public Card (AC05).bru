meta {
  name: Test Case 9 - Access Code Provided on Public Card (AC05)
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/creator-cards
  body: json
  auth: none
}

body:json {
  {
    "title": "Public Card",
    "creator_reference": "crt_q1w2e3r4t5y6u7i8",
    "status": "published",
    "access_type": "public",
    "access_code": "A1B2C3"
  }
}

assert {
  res.status: eq 400
  res.body.status: eq error
  res.body.code: eq AC05
}
