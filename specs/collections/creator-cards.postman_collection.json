		{
			"name": "Valid Scenarios",
			"item": [
				{
					"name": "Test Case 1 - Full Creation (Public Card)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Response is success status\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.status).to.eql(\"success\");",
									"});",
									"pm.test(\"Exposes id, never _id\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data.id).to.exist;",
									"    pm.expect(jsonData.data._id).to.not.exist;",
									"});",
									"pm.test(\"access_type defaults to public\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data.access_type).to.eql(\"public\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"George Cooks\",\n  \"description\": \"Weekly cooking podcast\",\n  \"slug\": \"george-cooks\",\n  \"creator_reference\": \"crt_8f2k1m9x4p7w3q5z\",\n  \"links\": [\n    {\n      \"title\": \"YouTube\",\n      \"url\": \"https://youtube.com/@georgecooks\"\n    }\n  ],\n  \"service_rates\": {\n    \"currency\": \"NGN\",\n    \"rates\": [\n      {\n        \"name\": \"IG Story Post\",\n        \"description\": \"One story mention\",\n        \"amount\": 5000000\n      }\n    ]\n  },\n  \"status\": \"published\"\n}"
